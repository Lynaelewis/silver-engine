from typing import Any, Optional, Iterable

class Node:
    def __init__(self, item: Any, link: Optional['Node'] = None) -> None:
        self.item = item
        self.link = link
    
    def __repr__(self) -> str:
        return f'Node({self.item})'

class LinkedList:
    def __init__(self, items: Optional[Iterable[Any]] = None) -> None:
        self._head = None
        self._tail = None
        self._size = 0
        if items:
            for item in items:
                self.add_last(item)
    
    def __len__(self) -> int:
        return self._size
    
    def get_head(self) -> Any:
        return self._head.item if self._head else None
    
    def get_tail(self) -> Any:
        return self._tail.item if self._tail else None
    
    def add_first(self, item: Any) -> None:
        self._head = Node(item, self._head)
        if not self._tail:
            self._tail = self._head
        self._size += 1
    
    def add_last(self, item: Any) -> None:
        new_node = Node(item)
        if self._tail:
            self._tail.link = new_node
        else:
            self._head = new_node
        self._tail = new_node
        self._size += 1
    
    def remove_first(self) -> Any:
        if not self._head:
            raise RuntimeError('LinkedList is empty')
        item = self._head.item
        self._head = self._head.link
        if not self._head:
            self._tail = None
        self._size -= 1
        return item
    
    def remove_last(self) -> Any:
        if not self._head:
            raise RuntimeError('linkedList is empty')
        if self._head == self._tail:
            item = self._head.item
            self._head = self._tail = None
            self._size = 0
            return item
        current = self._head
        while current.link != self._tail:
            current = current.link
        item = self._tail.item
        self._tail = current
        self._tail.link = None
        self._size -= 1
        return item
